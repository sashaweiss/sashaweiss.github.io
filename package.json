        "rollup": "^2.3.4",
        "rollup-plugin-copy": "^3.3.0",
        "rollup-plugin-css-only": "^3.1.0",
        "rollup-plugin-svelte": "^7.0.0",
        "rollup-plugin-terser": "^7.0.0",
        "sirv-cli": "^1.0.11",
        "svelte": "^3.0.0",
        "svelte-check": "^1.0.0",
        "svelte-preprocess": "^4.0.0",
